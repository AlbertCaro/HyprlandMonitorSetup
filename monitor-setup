#!/bin/bash
set -euo pipefail

CONF_DIR="$HOME/.config/hypr"

# Archivos que se alternan juntos: cada uno tiene .one.conf y .two.conf
BASES=("monitors" "workspaces")

# Determinar qué perfil está activo comparando el archivo principal con los perfiles
detect_current() {
  for profile in one two; do
    all_match=1
    for base in "${BASES[@]}"; do
      active="$CONF_DIR/$base.conf"
      candidate="$CONF_DIR/$base.$profile.conf"
      if [[ ! -f "$candidate" ]] || ! diff -q "$active" "$candidate" >/dev/null 2>&1; then
        all_match=0
        break
      fi
    done
    if [[ "$all_match" -eq 1 ]]; then
      echo "$profile"
      return
    fi
  done
  echo ""
}

# Verificar que existen todos los perfiles
for base in "${BASES[@]}"; do
  for profile in one two; do
    f="$CONF_DIR/$base.$profile.conf"
    if [[ ! -f "$f" ]]; then
      echo "Error: falta $base.$profile.conf en $CONF_DIR" >&2
      exit 1
    fi
  done
done

current="$(detect_current)"

# Decidir el siguiente perfil
case "${1:-}" in
  --one|1) next="one" ;;
  --two|2) next="two" ;;
  "")
    if [[ "$current" == "one" ]]; then
      next="two"
    elif [[ "$current" == "two" ]]; then
      next="one"
    else
      next="one"
    fi
    ;;
  *)
    echo "Uso: monitor-setup [--one|--two|1|2]" >&2
    exit 1
    ;;
esac

# Aplicar el cambio
for base in "${BASES[@]}"; do
  src="$CONF_DIR/$base.$next.conf"
  dst="$CONF_DIR/$base.conf"
  cp "$src" "$dst"
  echo "$base.conf <- $base.$next.conf"
done

echo "Setup activo: $next"

# Recargar Hyprland si está corriendo
if command -v hyprctl >/dev/null 2>&1 && hyprctl monitors >/dev/null 2>&1; then
  hyprctl reload
  echo "Hyprland recargado."
else
  echo "Hyprland no está corriendo; cambios aplicados al guardar."
fi
